<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="cube_bot">

  <xacro:property name="cube_size" value="0.4"/>
  <xacro:property name="wheel_radius" value="0.1"/>
  <xacro:property name="wheel_width" value="0.05"/>
  <xacro:property name="link_prefix" value="cube/"/>
  <xacro:property name="mast_height" value="0.1"/>
  <xacro:property name="arm_length" value="0.25"/>
  <xacro:arg name="robot_ns" default=""/>
  <xacro:property name="robot_ns" value="$(arg robot_ns)"/>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="${cube_size} ${cube_size} ${cube_size/2}"/>
      </geometry>
      <material name="cube_color">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${cube_size} ${cube_size} ${cube_size/2}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.2" ixy="0.0" ixz="0.0" iyy="0.2" iyz="0.0" izz="0.2"/>
    </inertial>
  </link>

  <xacro:macro name="wheel" params="name x y side">
    <link name="${name}_link">
      <visual>
        <origin rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black">
          <color rgba="0 0 0 1"/>
        </material>
      </visual>
      <collision>
        <origin rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_link"/>
      <origin
        xyz="${x} ${y + side * (cube_size/2 + wheel_width/2)} ${-cube_size/4 + wheel_radius -0.1}"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:macro name="rotor" params="name x y">
    <link name="${name}_link">
      <inertial>
        <mass value="0.05"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.0001" ixy="0" ixz="0"
                 iyy="0.0001" iyz="0"
                 izz="0.0002"/>
      </inertial>

      <visual>
        <geometry>
          <cylinder radius="0.1" length="0.01"/>
        </geometry>
      </visual>

      <collision>
        <geometry>
          <cylinder radius="0.1" length="0.01"/>
        </geometry>
      </collision>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_link"/>
      <origin xyz="${x} ${y} ${cube_size / 4 + 0.05}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit effort="10.0" velocity="500.0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel name="wheel_fl"
               x="${ cube_size/2}"
               y="${ 0}"
               side="1"/>

  <xacro:wheel name="wheel_rl"
               x="${-cube_size/2}"
               y="${ 0}"
               side="1"/>

  <xacro:wheel name="wheel_fr"
               x="${ cube_size/2}"
               y="${ 0}"
               side="-1"/>

  <xacro:wheel name="wheel_rr"
               x="${-cube_size/2}"
               y="${ 0}"
               side="-1"/>

  <xacro:rotor name="rotor_fl" x="${arm_length}"  y="${arm_length}" />
  <xacro:rotor name="rotor_fr" x="${arm_length}"  y="-${arm_length}"/>
  <xacro:rotor name="rotor_rl" x="-${arm_length}" y="${arm_length}" />
  <xacro:rotor name="rotor_rr" x="-${arm_length}" y="-${arm_length}"/>

  <link name="mast_link">
    <visual>
      <origin xyz="0 0 ${mast_height/2}"/>
      <geometry>
        <cylinder radius="0.03" length="${mast_height}"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${mast_height/2}"/>
      <geometry>
        <cylinder radius="0.03" length="${mast_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="mast_joint" type="fixed">
    <parent link="base_link"/>
    <child link="mast_link"/>
    <origin xyz="0 0 ${cube_size/2}"/>
  </joint>

  <link name="camera_link"/>
  <link name="lidar_link"/>

<joint name="camera_joint" type="fixed">
  <parent link="mast_link"/>
  <child link="camera_link"/>
  <origin xyz="0.02 0 ${mast_height}" rpy="0 0 1.5708"/>
</joint>


<joint name="lidar_joint" type="fixed">
  <parent link="mast_link"/>
  <child link="lidar_link"/>
  <origin xyz="0.02 0 ${mast_height}" rpy="0 0 1.5708"/>
</joint>

<!-- Sensors -->
  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <camera name="cube_camera">
        <horizontal_fov>1.9</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.2</near>
          <far>300</far>
        </clip>
      </camera>
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>camera/image_raw</topic>
      <gz_frame_id>camera_link</gz_frame_id>
    </sensor>
  </gazebo>

  <gazebo reference="lidar_link">
    <sensor name="lidar_link" type="gpu_lidar">
    <pose>0 0 0 0 0 0</pose>
      <topic>pointcloud</topic>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>640</samples>
            <min_angle>-1.396263</min_angle>
            <max_angle>1.396263</max_angle>
          </horizontal>
          <vertical>
            <samples>32</samples>
            <min_angle>-1.39</min_angle>
            <max_angle>1.39</max_angle>
          </vertical>
        </scan>
        <range>
          <min>1.0</min>
          <max>10.0</max>
        </range>
      </ray>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <gz_frame_id>lidar_link</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- Motion plugins -->
  <gazebo>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <robotNamespace>${robot_ns}</robotNamespace>
      <jointName>rotor_fl_joint</jointName>
      <linkName>rotor_fl_link</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1000.0</maxRotVelocity>
      <motorConstant>8.54858e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>motor_speed/0</commandSubTopic>
      <motorNumber>0</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <robotNamespace>${robot_ns}</robotNamespace>
      <jointName>rotor_fr_joint</jointName>
      <linkName>rotor_fr_link</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1000.0</maxRotVelocity>
      <motorConstant>8.54858e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>motor_speed/1</commandSubTopic>
      <motorNumber>1</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <robotNamespace>${robot_ns}</robotNamespace>
      <jointName>rotor_rl_joint</jointName>
      <linkName>rotor_rl_link</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1000.0</maxRotVelocity>
      <motorConstant>8.54858e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>motor_speed/2</commandSubTopic>
      <motorNumber>2</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <robotNamespace>${robot_ns}</robotNamespace>
      <jointName>rotor_rr_joint</jointName>
      <linkName>rotor_rr_link</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1000.0</maxRotVelocity>
      <motorConstant>8.54858e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>motor_speed/3</commandSubTopic>
      <motorNumber>3</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-control-system"
        name="gz::sim::systems::MulticopterVelocityControl">
        <robotNamespace>${robot_ns}</robotNamespace>
        <commandSubTopic>cmd_vel_air</commandSubTopic>
        <enableSubTopic>velocity_controller/enable</enableSubTopic>
        <comLinkName>base_link</comLinkName>
        <velocityGain>3.3 3.3 3.5</velocityGain>
        <attitudeGain>5.0 5.0 0.9</attitudeGain>
        <angularRateGain>1.5 1.5 0.09</angularRateGain>
        <maximumLinearAcceleration>2 2 2</maximumLinearAcceleration>
        <maximumLinearVelocity>5 5 5</maximumLinearVelocity>
        <maximumAngularVelocity>3 3 3</maximumAngularVelocity>
        <linearVelocityNoiseMean>0.0 0.0 0.0</linearVelocityNoiseMean>
        <linearVelocityNoiseStdDev>0.0 0.0 0.0</linearVelocityNoiseStdDev>
        <angularVelocityNoiseMean>0 0 0</angularVelocityNoiseMean>
        <angularVelocityNoiseStdDev>0.0 0.0 0.0</angularVelocityNoiseStdDev>
        <rotorConfiguration>
          <rotor>
            <jointName>rotor_fl_joint</jointName>
            <forceConstant>8.54858e-06</forceConstant>
            <momentConstant>0.016</momentConstant>
            <direction>1</direction>
          </rotor>
          <rotor>
            <jointName>rotor_fr_joint</jointName>
            <forceConstant>8.54858e-06</forceConstant>
            <momentConstant>0.016</momentConstant>
            <direction>-1</direction>
          </rotor>
          <rotor>
            <jointName>rotor_rl_joint</jointName>
            <forceConstant>8.54858e-06</forceConstant>
            <momentConstant>0.016</momentConstant>
            <direction>-1</direction>
          </rotor>
          <rotor>
            <jointName>rotor_rr_joint</jointName>
            <forceConstant>8.54858e-06</forceConstant>
            <momentConstant>0.016</momentConstant>
            <direction>1</direction>
          </rotor>
        </rotorConfiguration>
    </plugin>
    <plugin
      filename="libignition-gazebo-diff-drive-system.so"
      name="ignition::gazebo::systems::DiffDrive">
      <left_joint>wheel_fl_joint</left_joint>
      <right_joint>wheel_fr_joint</right_joint>
      <left_joint>wheel_rl_joint</left_joint>
      <right_joint>wheel_rr_joint</right_joint>
      <wheel_separation>${cube_size}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_publish_frequency>20</odom_publish_frequency>
      <topic>${robot_ns}/cmd_vel_ground</topic>
      <max_linear_acceleration>2.5</max_linear_acceleration>
      <max_angular_acceleration>3</max_angular_acceleration>
      <min_linear_acceleration>-2.5</min_linear_acceleration>
      <min_angular_acceleration>-3</min_angular_acceleration>
    </plugin>
    <plugin filename="libignition-gazebo-odometry-publisher-system.so" name="ignition::gazebo::systems::OdometryPublisher">
        <update_frequency>10</update_frequency>
        <odom_topic>${robot_ns}/true_pose</odom_topic>
        <odom_frame>odom</odom_frame>
        <dimensions>2</dimensions>
        <robot_base_frame>base_link</robot_base_frame>
        <tf_topic>${robot_ns}/tf</tf_topic>
    </plugin>
  </gazebo>

</robot>
