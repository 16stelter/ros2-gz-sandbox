<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="leo" 
               params="default_antenna:=true
                       rockers_fixed:=true
                       imu_translation:='0.0628 -0.0314 -0.0393'
                       mecanum_wheels:=false">
    <xacro:macro name="rocker_link" params="name">
      <link name="rocker_${name}_link">
        <inertial>
          <mass value="1.387336"/>
          <origin xyz="0 0.01346 -0.06506"/>
          <inertia
            ixx="0.002956" ixy="-0.000001489324" ixz="-0.000008103407"
            iyy="0.02924"  iyz="0.00007112"
            izz="0.02832"/>
        </inertial>
        <visual>
          <geometry>
            <mesh filename="package://leo/Rocker.dae"/>
          </geometry>
        </visual>
        <collision>
          <geometry>
            <mesh filename="package://leo/Rocker_outline.stl"/>
          </geometry>
        </collision>
      </link>
    </xacro:macro>

    <xacro:macro name="wheel_link" params="name model"> 
      <link name="wheel_${name}_link">
        <inertial>
          <mass value="0.283642"/>
          <origin xyz="0 0.030026 0"/>
          <inertia
            ixx="0.000391"  ixy="0.00000123962" ixz="5.52582e-7"
            iyy="0.0004716" iyz="-0.000002082042"
            izz="0.000391"/>
        </inertial>
        <visual>
          <geometry>
            <mesh filename="package://leo/Wheel${model}.dae"/>
          </geometry>
        </visual>
        <collision>
          <origin xyz="0 0.04485 0" rpy="${pi/2} 0 0"/>
          <geometry>
            <cylinder radius="0.057" length="0.07"/>
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0.04485 0" rpy="${pi/2} 0 0"/>
          <geometry>
            <cylinder radius="0.0625" length="0.04"/>
          </geometry>
        </collision>
        <collision>
          <geometry>
            <mesh filename="package://leo/Wheel_outline.stl"/>
          </geometry>
        </collision>
      </link>
    </xacro:macro>

    <xacro:macro name="mecanum_wheel_link" params="name model"> 
      <link name="wheel_${name}_link">
        <inertial>
          <mass value="0.672214"/>
          <origin xyz="0 -0.036852 0"/>
          <inertia
            ixx="0.0009778"  ixy="-8.10228e-7" ixz="3.2e-11"
            iyy="0.001321" iyz="5.7e-11"
            izz="0.0009773"/>
        </inertial>
        <visual>
          <geometry>
            <mesh filename="package://leo/WheelMecanum${model}.dae"/>
          </geometry>
        </visual>
        <collision>
          <origin xyz="0 -0.0317 0" rpy="${pi/2} 0 0"/>
          <geometry>
            <cylinder radius="0.0635" length="0.0515"/>
          </geometry>
        </collision>
        <collision>
          <geometry>
            <mesh filename="package://leo/Mecanum_wheel_outline.stl"/>
          </geometry>
        </collision>
      </link>
    </xacro:macro>

    <!-- LINKS -->

    <link name="base_link">
      <pose>0 0 0.19783 0 0 0</pose>
      <inertial>
        <mass value="1.584994"/>
        <origin xyz="-0.019662 0.011643 -0.031802"/>
        <inertia
          ixx="0.01042" ixy="0.001177" ixz="-0.0008871"
          iyy="0.01045" iyz="0.0002226"
          izz="0.01817"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://leo/Chassis.dae"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://leo/Chassis_outline.stl"/>
        </geometry>
      </collision>
    </link>

    <xacro:rocker_link name="L"/>
    <xacro:rocker_link name="R"/>
    <xacro:if value="${mecanum_wheels}">
      <xacro:mecanum_wheel_link name="FL" model="B"/>
      <xacro:mecanum_wheel_link name="RL" model="A"/>
      <xacro:mecanum_wheel_link name="FR" model="A"/>
      <xacro:mecanum_wheel_link name="RR" model="B"/>
    </xacro:if>
    <xacro:unless value="${mecanum_wheels}">
      <xacro:wheel_link name="FL" model="A"/>
      <xacro:wheel_link name="RL" model="A"/>
      <xacro:wheel_link name="FR" model="B"/>
      <xacro:wheel_link name="RR" model="B"/>
    </xacro:unless>

    <xacro:if value="${default_antenna}">
      <link name="antenna_link">
        <inertial>
          <mass value="0.001237"/>
          <origin xyz="0 0 0.028828"/>
          <inertia
            ixx="2.5529e-7" ixy="0.0" ixz="0.0"
            iyy="2.5529e-7" iyz="0.0"
            izz="1.354e-8"/>
        </inertial>
        <visual>
          <geometry>
            <mesh filename="package://leo/Antenna.dae"/>
          </geometry>
        </visual>
        <collision>
          <origin xyz="0 0 0.028"/>
          <geometry>
            <cylinder radius="0.0055" length="0.056"/>
          </geometry>
        </collision>
      </link>
    </xacro:if>

    <link name="camera_frame"/>
    <link name="lidar_frame"/>
    <link name="camera_optical_frame"/>
    <link name="imu_frame"/>


    <!-- JOINTS -->
    <xacro:if value="${rockers_fixed}">
      <xacro:property name="rockers_joint_type" value="fixed"/>
    </xacro:if>
    <xacro:unless value="${rockers_fixed}">
      <xacro:property name="rockers_joint_type" value="revolute"/>
    </xacro:unless>

    <joint name="rocker_L_joint" type="${rockers_joint_type}">
      <origin xyz="0.00263 0.14167 -0.04731" rpy="0 0 ${pi}"/>
      <parent link="base_link"/>
      <child link="rocker_L_link"/>
      <axis xyz="0 1 0"/>
      <limit effort="100.0" lower="-0.24" upper="0.24" velocity="100.0"/>
      <dynamics friction="1.0" damping="0.1"/>
    </joint>

    <joint name="rocker_R_joint" type="${rockers_joint_type}">
      <origin xyz="0.00263 -0.14167 -0.04731" rpy="0 0 0"/>
      <parent link="base_link"/>
      <child link="rocker_R_link"/>
      <axis xyz="0 1 0"/>
      <limit effort="100.0" lower="-0.24" upper="0.24" velocity="100.0"/>
      <dynamics friction="1.0" damping="0.1"/> 
      <mimic joint="rocker_L_joint"/>
    </joint>

    <joint name="wheel_FL_joint" type="continuous">
      <xacro:if value="${mecanum_wheels}">
        <origin xyz="-0.15256 -0.00884 -0.08802" rpy="0 0 0"/>
      </xacro:if>
      <xacro:unless value="${mecanum_wheels}">
        <origin xyz="-0.15256 -0.08214 -0.08802" rpy="0 0 0"/>
      </xacro:unless>
      <parent link="rocker_L_link"/>
      <child link="wheel_FL_link"/>
      <axis xyz="0 -1 0"/>
      <limit effort="2.0" velocity="6.0"/>
      <dynamics friction="0.3125" damping="0.1"/>
    </joint>

    <joint name="wheel_RL_joint" type="continuous">
      <xacro:if value="${mecanum_wheels}">
        <origin xyz="0.15256 -0.00884 -0.08802" rpy="0 0 0"/>
      </xacro:if>      
      <xacro:unless value="${mecanum_wheels}">
        <origin xyz="0.15256 -0.08214 -0.08802" rpy="0 0 0"/>
      </xacro:unless>
      <parent link="rocker_L_link"/>
      <child link="wheel_RL_link"/>
      <axis xyz="0 -1 0"/>
      <limit effort="2.0" velocity="6.0"/>
      <dynamics friction="0.3125" damping="0.1"/>
    </joint>

    <joint name="wheel_FR_joint" type="continuous">
      <xacro:if value="${mecanum_wheels}">
        <origin xyz="0.15256 -0.00884 -0.08802" rpy="0 0 0"/>
      </xacro:if>
      <xacro:unless value="${mecanum_wheels}">
        <origin xyz="0.15256 -0.08214 -0.08802" rpy="0 0 0"/>
      </xacro:unless>
      <parent link="rocker_R_link"/>
      <child link="wheel_FR_link"/>
      <axis xyz="0 1 0"/>
      <limit effort="2.0" velocity="6.0"/>
      <dynamics friction="0.3125" damping="0.1"/>
    </joint>

    <joint name="wheel_RR_joint" type="continuous">
      <xacro:if value="${mecanum_wheels}">
        <origin xyz="-0.15256 -0.00884 -0.08802" rpy="0 0 0"/>
      </xacro:if>
      <xacro:unless value="${mecanum_wheels}">
        <origin xyz="-0.15256 -0.08214 -0.08802" rpy="0 0 0"/>
      </xacro:unless>
      <parent link="rocker_R_link"/>
      <child link="wheel_RR_link"/>
      <axis xyz="0 1 0"/>
      <limit effort="2.0" velocity="6.0"/>
      <dynamics friction="0.3125" damping="0.1"/> 
    </joint>

    <xacro:if value="${default_antenna}">
      <joint name="antenna_joint" type="fixed">
        <origin xyz="-0.0052 0.056 -0.0065" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="antenna_link"/>
      </joint>
    </xacro:if>

    <joint name="lidar_joint" type="fixed">
      <origin xyz="0.0971 0 -0.0427" rpy="0 0.2094 0"/>
      <parent link="base_link"/>
      <child link="lidar_frame"/>
    </joint>

    <joint name="camera_joint" type="fixed">
      <origin xyz="0.0971 0 -0.0427" rpy="0 0.2094 0"/>
      <parent link="base_link"/>
      <child link="camera_frame"/>
    </joint>

    <joint name="camera_optical_joint" type="fixed">
      <origin xyz="0 0 0" rpy="-${pi/2} 0.0 -${pi/2}"/>
      <parent link="camera_frame"/>
      <child link="camera_optical_frame"/>
    </joint>

    <joint name="imu_joint" type="fixed">
      <origin xyz="${imu_translation}" rpy="0 0 0"/>
      <parent link="base_link"/>
      <child link="imu_frame"/>
    </joint>
  </xacro:macro>

  <!-- LEO GAZEBO -->

  <xacro:macro name="leo_gazebo"
               params="robot_ns:=''">

    <!-- base ODE properties -->
    <gazebo reference="base_link">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
            <bullet>
              <friction>0.3</friction>
              <friction2>0.3</friction2>
              <rolling_friction>0.1</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </gazebo>

    <gazebo reference="base_link">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
            <bullet>
              <friction>0.3</friction>
              <friction2>0.3</friction2>
              <rolling_friction>0.1</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </gazebo>

    <!-- rocker ODE properties -->
    <gazebo reference="rocker_L_link">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
            <bullet>
              <friction>0.3</friction>
              <friction2>0.3</friction2>
              <rolling_friction>0.1</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </gazebo>

    <gazebo reference="rocker_R_link">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
            <bullet>
              <friction>0.3</friction>
              <friction2>0.3</friction2>
              <rolling_friction>0.1</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </gazebo>
    <!-- wheel ODE properties -->
    <gazebo reference="wheel_FL_link">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>1</mu>
              <mu2>1</mu2>
              <slip1>0.01</slip1>
              <slip2>0.01</slip2>
            </ode>
            <bullet>
              <friction>1</friction>
              <friction2>1</friction2>
              <rolling_friction>0</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </gazebo>

    <gazebo reference="wheel_FR_link">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>1</mu>
              <mu2>1</mu2>
              <slip1>0.01</slip1>
              <slip2>0.01</slip2>
            </ode>
            <bullet>
              <friction>1</friction>
              <friction2>1</friction2>
              <rolling_friction>0</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </gazebo>

    <gazebo reference="wheel_RL_link">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>1</mu>
              <mu2>1</mu2>
              <slip1>0.01</slip1>
              <slip2>0.01</slip2>
            </ode>
            <bullet>
              <friction>1</friction>
              <friction2>1</friction2>
              <rolling_friction>0</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </gazebo>

    <gazebo reference="wheel_RR_link">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>1</mu>
              <mu2>1</mu2>
              <slip1>0.01</slip1>
              <slip2>0.01</slip2>
            </ode>
            <bullet>
              <friction>1</friction>
              <friction2>1</friction2>
              <rolling_friction>0</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </gazebo>

    <!-- camera -->
    <gazebo reference="camera_frame">
      <sensor name="camera" type="camera">
          <camera name="leo_camera">
              <horizontal_fov>1.9</horizontal_fov>
              <image>
                  <width>640</width>
                  <height>480</height>
                  <format>R8G8B8</format>
              </image>
              <clip>
                  <near>0.2</near>
                  <far>300</far>
              </clip>
              <noise>
                <type>gaussian</type>
                <mean>0.0</mean>
                <stddev>0.007</stddev>
              </noise>
              <distortion>
                <k1>-0.279817</k1>
                <k2>0.060321</k2>
                <k3>0.000487</k3>
                <p1>0.000310</p1>
                <p2>0.000000</p2>
                <center>0.5 0.5</center>
              </distortion>              
          </camera>
          <always_on>1</always_on>
          <update_rate>30</update_rate>
          <visualize>true</visualize>
          <topic>${robot_ns}/camera/image_raw</topic>
          <gz_frame_id>camera_frame</gz_frame_id>
      </sensor>
    </gazebo>

    <!-- fake lidar for sim-->
    <gazebo reference="lidar_frame">
      <sensor name='lidar_frame' type='gpu_lidar'>
        <pose relative_to='lidar_frame'>0 0 0 0 0 0</pose>
        <topic>${robot_ns}/pointcloud</topic>
        <update_rate>10</update_rate>
        <ray>
          <scan>
            <horizontal>
              <samples>640</samples>
              <resolution>1</resolution>
              <min_angle>-1.396263</min_angle>
              <max_angle>1.396263</max_angle>
            </horizontal>
            <vertical>
              <samples>32</samples>
              <resolution>0.01</resolution>
              <min_angle>-1.39</min_angle>
              <max_angle>1.39</max_angle>
            </vertical>
          </scan>
          <range>
            <min>1.0</min>
            <max>10.0</max>
            <resolution>0.01</resolution>
          </range>
        </ray>
        <always_on>true</always_on>
        <visualize>true</visualize>
        <gz_frame_id>lidar_frame</gz_frame_id>
      </sensor>
    </gazebo>

    <!-- rocker differential -->

    <gazebo>
      <plugin
        filename="ignition-gazebo-joint-state-publisher-system"
        name="ignition::gazebo::systems::JointStatePublisher">
        <topic>${robot_ns}/joint_states</topic>
      </plugin>
    </gazebo>

    <gazebo reference="imu_frame">
      <sensor type="imu" name="leo_imu_sensor">
        <update_rate>100</update_rate>
        <visualize>true</visualize>
        <topic>${robot_ns}/imu/data_raw</topic>
        <always_on>1</always_on>
        <gz_frame_id>imu_frame</gz_frame_id>
      </sensor>
    </gazebo>
    <gazebo>
      <plugin
        filename="libignition-gazebo-diff-drive-system.so"
        name="ignition::gazebo::systems::DiffDrive">
        <left_joint>wheel_FL_joint</left_joint>
        <right_joint>wheel_FR_joint</right_joint>
        <left_joint>wheel_RL_joint</left_joint>
        <right_joint>wheel_RR_joint</right_joint>
        <wheel_separation>0.358</wheel_separation>
        <wheel_radius>0.0625</wheel_radius>
        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
        <odom_publish_frequency>20</odom_publish_frequency>
        <topic>${robot_ns}/cmd_vel</topic>
        <max_linear_acceleration>2.5</max_linear_acceleration>
        <max_angular_acceleration>3</max_angular_acceleration>
        <min_linear_acceleration>-2.5</min_linear_acceleration>
        <min_angular_acceleration>-3</min_angular_acceleration>
      </plugin>
      <plugin filename="libignition-gazebo-odometry-publisher-system.so" name="ignition::gazebo::systems::OdometryPublisher">
        <update_frequency>10</update_frequency>
        <odom_topic>${robot_ns}/true_pose</odom_topic>
        <odom_frame>odom</odom_frame>
        <dimensions>2</dimensions>
        <robot_base_frame>base_link</robot_base_frame>
        <tf_topic>${robot_ns}/tf</tf_topic>
      </plugin>
    </gazebo>
    
  </xacro:macro>

  <xacro:macro name="leo_sim" 
               params="default_antenna:=true 
                       fixed:=false
                       robot_ns:=''
                       mecanum_wheels:=false">
    <xacro:leo default_antenna="${default_antenna}"
               rockers_fixed="false"
               mecanum_wheels="${mecanum_wheels}"/>

    <xacro:leo_gazebo robot_ns="${robot_ns}"/>

    <xacro:if value="${fixed}">
      <link name="odom"/>
      <joint name="fixed" type="fixed">
        <parent link="odom"/>
        <child link="base_link"/>
        <origin xyz="0.0 0.0 1.0"/>
      </joint>
    </xacro:if>
  
  </xacro:macro>

</robot>
